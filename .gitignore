# ─────────────────────────────────────────────
# 시크릿 (RULES.md 4.1 — 절대 커밋 금지)
# ─────────────────────────────────────────────
.env
.env.*
# 값이 없는 예시 파일은 커밋 대상 (! = 무시 예외)
!.env.example
*.json.key
*-credentials.json
*service-account*.json
secrets/

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ─────────────────────────────────────────────
# Terraform (state에는 시크릿이 포함될 수 있음)
# ─────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
# 변수 값에 프로젝트 ID 등 포함 → 예시는 *.tfvars.example로만 커밋
# (주의: .gitignore는 패턴 뒤에 주석을 붙이면 패턴이 깨진다 — 주석은 반드시 별도 줄에)
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl 은 커밋한다 — 팀 전체가 동일한 프로바이더 버전을 쓰도록 고정하는 파일

# ─────────────────────────────────────────────
# dbt / Airflow 로컬 산출물
# ─────────────────────────────────────────────
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml
airflow/logs/
airflow/*.db
airflow/*.pid

# ─────────────────────────────────────────────
# IDE / OS
# ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
Thumbs.db
.DS_Store
