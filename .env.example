# 이 파일을 `.env` 로 복사한 뒤 실제 값을 채운다.
# .env 는 .gitignore 에 있어 절대 커밋되지 않는다 (RULES.md 4.1)
# ⚠️ 이 .example 파일 자체는 git에 커밋된다 — 여기에 실제 키를 쓰면 안 된다!
# 공공데이터포털 마이페이지 → 일반 인증키(Decoding) 값을 넣는다.
DATA_GO_KR_SERVICE_KEY=여기에_디코딩_인증키

# 식품안전나라(foodsafetykorea.go.kr) keyId — 공공데이터포털과 별개 서비스
FOODSAFETYKOREA_KEY_ID=여기에_keyId

# 데이터 레이크 버킷 이름 (terraform output data_lake_bucket 값)
GCS_RAW_BUCKET=여기에_버킷이름
